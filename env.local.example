# Supabase project URL (Project Settings > Data API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase PUBLISHABLE key (sb_publishable_...). Safe to expose to the browser.
# Do NOT put the sb_secret_... key here. The app shell never needs it; it only
# arrives later for the server-side crawl/widget routes, in a non-public var.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
