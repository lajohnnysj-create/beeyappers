# ---- Public (safe to expose to the browser) ----
# Supabase project URL (Settings > Data API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase PUBLISHABLE key (sb_publishable_...). Public by design.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ---- Server-only secrets (NEVER prefix with NEXT_PUBLIC, never commit) ----
# Supabase SECRET / service_role key (sb_secret_...). Bypasses RLS.
# Used only by server code (the crawl route) to write pages/chunks.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# OpenAI API key for embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
